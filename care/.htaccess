RewriteEngine On

# Skip real files/dirs
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Clean URLs: pagename → index.php?page=pagename
RewriteRule ^api\.php$ - [L]
RewriteRule ^([a-z0-9-]+)/?$ /zerdatime/care/index.php?page=$1 [L,QSA]
RewriteRule ^([a-z0-9-]+)/([a-zA-Z0-9-]+)/?$ /zerdatime/care/index.php?page=$1&id=$2 [L,QSA]
