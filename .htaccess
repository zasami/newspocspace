RewriteEngine On
RewriteBase /newspocspace/

# --- Security hardening ---

# Block access to dotfiles (.env, .git, .htaccess, .gitignore, .DS_Store, etc.)
<FilesMatch "^\.">
  <IfModule mod_authz_core.c>
    Require all denied
  </IfModule>
  <IfModule !mod_authz_core.c>
    Order allow,deny
    Deny from all
  </IfModule>
</FilesMatch>

# Block any URL path that traverses a VCS folder (.git, .svn, .hg, .bzr)
# even for non-dot files inside (e.g. .git/config is a "file" named config).
RewriteRule (^|/)\.(git|svn|hg|bzr)(/|$) - [F,L]

# Block common sensitive filenames regardless of directory
RewriteRule (^|/)(composer\.(json|lock)|package(-lock)?\.json|yarn\.lock|\.env.*|Dockerfile|docker-compose\.ya?ml)$ - [F,L,NC]

# Block .env* variants explicitly
<FilesMatch "^\.env($|\..*)">
  <IfModule mod_authz_core.c>
    Require all denied
  </IfModule>
  <IfModule !mod_authz_core.c>
    Order allow,deny
    Deny from all
  </IfModule>
</FilesMatch>

# Block composer/git/lock/sql/md files from direct download
<FilesMatch "\.(lock|sql|md|json|log)$">
  <IfModule mod_authz_core.c>
    Require all denied
  </IfModule>
  <IfModule !mod_authz_core.c>
    Order allow,deny
    Deny from all
  </IfModule>
</FilesMatch>

# Allow manifest.json (PWA) + raw_gemini.json should be deleted, but just in case
<Files "manifest.json">
  <IfModule mod_authz_core.c>
    Require all granted
  </IfModule>
  <IfModule !mod_authz_core.c>
    Order allow,deny
    Allow from all
  </IfModule>
</Files>

# Disable directory listing globally
Options -Indexes

# Disable MultiViews (prevents content negotiation attacks)
Options -MultiViews

# Prevent server signature in responses
ServerSignature Off

# Service Worker must never be cached by browser
<Files "sw.js">
  Header set Cache-Control "no-cache, no-store, must-revalidate"
  Header set Pragma "no-cache"
  Header set Expires "0"
</Files>

# Don't rewrite files or directories
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Don't rewrite admin, care, api, old, Cahier des charges
RewriteRule ^admin/ - [L]
RewriteRule ^care/ - [L]
RewriteRule ^api\.php - [L]
RewriteRule ^old/ - [L]
RewriteRule ^Cahier - [L]

# Route everything else to index.php (SPA)
RewriteRule ^(.*)$ index.php [L,QSA]
